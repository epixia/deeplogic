PORT=8787
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=<local anon key from 'supabase status'>
SUPABASE_SERVICE_ROLE_KEY=<local service_role key from 'supabase status'>

# App base URL (used for invite email links, billing redirects)
APP_URL=http://localhost:5173

# Resend (https://resend.com) — leave blank to log emails to stdout in dev
RESEND_API_KEY=
EMAIL_FROM=DeepLogic <noreply@yourdomain.com>

# Stripe (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_TEAM=price_...
STRIPE_PRICE_BUSINESS=price_...

# Super-admin access — comma-separated emails that can access /api/admin/* and /admin UI
ADMIN_EMAILS=you@yourcompany.com

# Brave Search API (https://api.search.brave.com — free tier: 2000 queries/month)
# Powers the web research toggle in the vibe-code chat composer.
BRAVE_SEARCH_API_KEY=

# e2b (https://e2b.dev) — isolated sandboxes for Studio HTML preview and the
# Innovation Lab (vibecode tools run here). Required for both.
E2B_API_KEY=

# LiveAvatar (https://app.liveavatar.com/developers) — realtime avatar for the
# staff interviewer. HeyGen's old streaming API was sunset; this is the current one.
# Needs wallet balance on the LiveAvatar account for live sessions.
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=        # a LiveAvatar avatar UUID
HEYGEN_VOICE_ID=         # optional

# Vapi (https://vapi.ai) — phone-call interviews. The agent calls a staff member,
# runs the mind-dump persona, and the transcript is ingested via the webhook.
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=    # a Vapi-provisioned number to call FROM
VAPI_VOICE_ID=           # optional (default: Elliot)
VAPI_WEBHOOK_SECRET=     # optional shared secret (sent as x-vapi-secret)
# Public URL of THIS server so Vapi can POST the transcript (use ngrok in dev):
PUBLIC_API_URL=          # e.g. https://api.yourdomain.com  (no trailing slash)

# Employee enrichment — the "Fetch from LinkedIn" button pulls a company's people
# via a people-data provider. Use a legitimate basis and comply with the
# provider's ToS + applicable privacy law (this uses an API, not scraping).
ENRICH_PROVIDER=apollo    # apollo | proxycurl
ENRICH_API_KEY=
